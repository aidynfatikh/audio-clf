# Secrets / env
.env

# Raw data & model weights (large, non-reproducible via code alone)
data/
models/
models*/
*.pt

# Logs / run artifacts
*.log
*.err
*.out
*.log.gz
*.log.bz2
*.log.xz
*.log.lzma
*.log.zstd
wandb/
.gradio
el_audios/
eval-baseline
results*/
01_hold_lr_run/
02_warmup_lr_run/
03_regularized_run/
kazemotts_emotion_metrics.json

# Built split artifacts (parquet + summary.json + resolved config) are
# regenerated by `scripts/build_splits.py` from `configs/splits/*.yaml`,
# which is the tracked source of truth. Ignore the build output but
# keep the Python package (incl. tests/).
splits/*/
!splits/tests/

# Python
__pycache__/
*.pyc
.pytest_cache/

# IDE / OS junk
.vscode/
.idea/
.DS_Store

# Scratch
test
paper/
